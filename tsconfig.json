{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/*"],
      "@worker/*": ["./worker/src/*"]
    },
    "skipLibCheck": true,
    "strict": true,
    "types": ["vitest/globals"]
  },
  "include": [
    ".wxt/wxt.d.ts",
    "entrypoints",
    "src",
    "test",
    "wxt.config.ts",
    "vitest.config.ts"
  ]
}
